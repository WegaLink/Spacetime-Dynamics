<p1:Tab  xmlns="http://www.eclipse.org/xwt/presentation" xmlns:x="http://www.eclipse.org/xwt" xmlns:p1="clr-namespace:com.ifx.davex.ui.controls.app" x:Class="e" layout="{x:Null}">
	<p1:TabFolder bounds="5, 5, 533, 975">
		      <p1:GTab text="General" widgetName="gtab_general" visible="true" enabled="true" manifestObj="true">
            <p1:GTab.control>
                <p1:Tab layout="{x:Null}">
                    <p1:GGroup bounds="12, 11, 501, 155" manifestObj="true" text="Operation Mode" widgetName="ggroup_operation_mode">
                        <p1:GLabel bounds="14, 24, 73, 15" manifestObj="true" text="Device type:" widgetName="glabel_device_type"/>
                        <p1:GCombo bounds="257, 21, 179, 21" description="Device or bus mode kind.&lt;br&gt;&#13;&#10;&lt;ul&gt;&#13;&#10;&lt;li&gt;Master: the peripheral operates as the master in a I2C communication, that is, it is the one that provides the clock.&lt;/li&gt;&#13;&#10;&lt;li&gt;Slave: the peripheral operates as the slave in a I2C communication. It needs the clock provided by a master for communication.&lt;/li&gt;&#13;&#10;&lt;/ul&gt;" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" options="Master&#13;&#10;Slave" value="Master" widgetName="gcombo_device_type"/>
                        <p1:GCheck bounds="14, 55, 277, 16" description="On selecting this option, the transmit data validation is enabled. This means, that an input signal (Shift Control Input DX2) can be used for enabling/disabling the data word transfer with the use of a transfer gating logic or for starting the data transfer upon the reception of an event with the use of a transfer trigger logic." manifestObj="true" text="Use input stage DX2 for transmit data validation" widgetName="gcheck_enable_transmit_enable"/>
                        <p1:GLabel bounds="14, 89, 156, 15" manifestObj="true" text="Start of data transfer:" widgetName="glabel_type_transmit_data_validation" toolTipText="Setting of bitfield TCSR.TDEN"/>
                        <p1:GCombo bounds="257, 86, 179, 21" description="Type of transmit data validation used.&lt;br&gt;&#13;&#10;&lt;ul&gt;&#13;&#10;&lt;li&gt;Transfer on low (DX2S = 0): Transfer gating logic is used. A transmission of the data word in TBUF can be started if the value of the signal DX2S is equal to zero.&lt;/li&gt;&#13;&#10;&lt;li&gt;Transfer on high (DX2S = 1):  Also the transfer gating logic is used, but in this case, the transmission can be started if the value of the signal DX2S is equal to one.&lt;/li&gt;&#13;&#10;&lt;li&gt;Transfer on event (DX2T): A transfer trigger logic is made use of. Data word transfers are triggered by events.&lt;/li&gt;&#13;&#10;&lt;/ul&gt;" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" options="Transfer On Low (DX2S = 0)&#13;&#10;Transfer On High (DX2S = 1)&#13;&#10;Transfer On Event (DX2T)" value="Transfer On Low (DX2S = 0)" widgetName="gcombo_type_transmit_data_validation" toolTipText="Setting of bitfield TCSR.TDEN"/>
                        <p1:GLabel bounds="14, 122, 237, 15" manifestObj="true" text="Triggering edge for data validation on event:" widgetName="glabel_transmit_data_validation_trigger_edge" toolTipText="Setting of bitfield DX2CR.CM"/>
                        <p1:GCombo bounds="257, 119, 179, 21" description="This field defines the edge of the DX2T signal to be used for triggering the transmit data validation.&lt;br&gt;&#13;&#10;&lt;ul&gt;&#13;&#10;&lt;li&gt;Rising Edge: The rising edge of the DX2T signal is used.&lt;/li&gt;&#13;&#10;&lt;li&gt;Falling Edge: The rising edge of the DX2T signal is used.&lt;/li&gt;&#13;&#10;&lt;/ul&gt;" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" options="Rising Edge&#13;&#10;Falling Edge&#13;&#10;Both Edges" value="Rising Edge" widgetName="gcombo_transmit_data_validation_trigger_edge" toolTipText="Setting of bitfield DX2CR.CM"/>
                    </p1:GGroup>
                    <p1:GGroup text="Address Settings" manifestObj="true" widgetName="ggroup_slave_address_settings" bounds="12, 181, 501, 132">
                        <p1:GInteger bounds="123, 59, 54, 23" description="Address of the device in slave mode. Maximum value depends on the number of bits selected for slave address. A 7-bit address should include an additional bit at the LSB for read/write indication. For example, address 0x05 should be provided as 0x0a. A 10-bit address should be provided with the identifier 0b11110xx at the most significant bits. For example, address 0x305 should be provided as 0x7b05(bitwise OR with 0x7800)" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="127" minValue="0" toolTipText="Setting of the bitfield" value="0" widgetName="ginteger_slave_address"/>
                        <p1:GLabel bounds="12, 63, 86, 15" manifestObj="true" text="Address:" toolTipText="Setting of the bitfield" widgetName="glabel_slave_address"/>
                        <p1:GCheck bounds="12, 99, 217, 16" manifestObj="true" text="Enable slave sensitivity to 00 address" widgetName="gcheck_enable_sensitivity_00_address" description="This checkbox enables the slave to acknowledge slave address 0."/>
                        <p1:GLabel bounds="12, 27, 70, 15" manifestObj="true" text="Mode [bits]:" toolTipText="Setting of the bitfield" widgetName="glabel_addressing_mode"/>
                        <p1:GCombo mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" widgetName="gcombo_addressing_mode" bounds="123, 24, 54, 21" options="7&#13;&#10;10" value="7" description="Allows selection of number of address bits for slave device." toolTipText="Select number of slave address bits"/>
                    </p1:GGroup>
                    <p1:GGroup manifestObj="true" text="Multi-master " widgetName="ggroup_multi_master" bounds="12, 181, 501, 98">
                            <p1:GCheck bounds="12, 26, 135, 16" manifestObj="true" text="Enable multi-master" widgetName="gcheck_enable_multi_master" description="Allows the I2C master device to act as slave when a different device wins bus arbitration."/>
                            <p1:GInteger bounds="123, 60, 54, 23" description="In multi master arrangement, this value will be the address for this master.&lt;br&gt;&#13;&#10;7bit or 10bit will be determined based on the value entered. A 7-bit address should include an additional bit at the LSB for read/write indication. For example, address 0x05 should be provided as 0x0a. A 10-bit address should be provided with the identifier 0b11110xx at the most significant bits. For example, address 0x305 should be provided as 0x7b05(bitwise OR with 0x7800)" enabled="false" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="65535" minValue="0" toolTipText="Setting of the bitfield PCR_IICmode.SLAD&#13;&#10;For 10bit address, bitwise OR the value with (0x7c00)." value="0" widgetName="ginteger_master_address"/>
                            <p1:GLabel bounds="12, 64, 86, 15" manifestObj="true" text="Address:" toolTipText="Setting of the bitfield" widgetName="glabel_master_address"/>
                        </p1:GGroup>
                    <p1:GGroup bounds="12, 294, 501, 503" manifestObj="true" text="Baud Rate Generator" widgetName="ggroup_baud_rate">
                        <p1:GLabel bounds="13, 70, 133, 15" manifestObj="true" text="Desired bus speed [kHz]:" widgetName="glabel_desired_baud_rate"/>
                        <p1:GInteger bounds="163, 66, 147, 23" description="Allows to configure the desired baud rate for the I2C communication. The value should be specified in kilo hertz. " format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="400" minValue="1" value="100" widgetName="ginteger_desired_baud_rate"/>
                        <p1:GImage bounds="15, 238, 470, 175" manifestObj="true" path="doc/I2C_CONFIG_brg_internal_clk.png" widgetName="gimage_baud_rate"/>
                        <p1:GCheck bounds="13, 461, 186, 16" description="On selecting this option, the capture mode timer is enabled during initialization." manifestObj="true" text="Enable the capture mode timer" widgetName="gcheck_enable_capture_mode_timer" toolTipText="Setting of bitfield BRG.TMEN"/>
                        <p1:GLabel bounds="13, 424, 127, 15" manifestObj="true" text="Actual bus speed [kHz]:" widgetName="glabel_real_baud_rate"/>
                        <p1:GInteger bounds="163, 420, 147, 23" description="Indicates the actual frequency that can be achieved by the peripheral. This value is calculated based on the entered value of desired baud rate." enabled="false" format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="400" minValue="1" value="100" widgetName="ginteger_real_baud_rate"/>
                        <p1:GLabel bounds="13, 106, 90, 15" manifestObj="true" text="Divider factor:" toolTipText="Setting of bitfield BRG.PDIV + 1" widgetName="glabel_divider_factor"/>
                        <p1:GInteger bounds="163, 102, 147, 23" description="This field indicates the ratio between the input frequency fPPP and the divider frequency fPDIV. &lt;br&gt;&#13;&#10;Bitfield BRG.PDIV + 1" enabled="false" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="1024" minValue="1" toolTipText="Setting of bitfield BRG.PDIV + 1" value="1" widgetName="ginteger_divider_factor"/>
                        <p1:GLabel bounds="13, 141, 90, 15" manifestObj="true" text="Symbol timing:" toolTipText="Setting of bitfield BRG.DCTQ + 1" widgetName="glabel_symbol_timing_master"/>
                        <p1:GInteger bounds="163, 137, 147, 23" description="Number of samples to be taken for deciding the value of each I2C symbol(logic 0 or 1).&lt;br&gt;&#13;&#10;Bit field (BRG.DCTQ + 1)" enabled="false" format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="25" minValue="10" toolTipText="Setting of bitfield BRG.DCTQ + 1" value="10" widgetName="ginteger_symbol_timing_master"/>
                        <p1:GLabel bounds="13, 70, 86, 15" manifestObj="true" text="Edge selection:" widgetName="glabel_external_clock_edge" toolTipText="Setting of bitfield DX1CR.CM"/>
                        <p1:GCombo bounds="163, 67, 147, 21" description="This field selects which edge of the external source signal (DX1S) must be used to generate the clock signal (DX1T)&#13;&#10;&lt;ul&gt;&#13;&#10;&lt;li&gt;Rising Edge: The rising edge of the external signal generates the clock signal.&lt;/li&gt;&#13;&#10;&lt;li&gt;Falling Edge: The falling edge of the external signal generates the clock signal.&lt;/li&gt;&#13;&#10;&lt;li&gt;Both Edges: Both edges of the external signal generate the clock signal.&lt;/li&gt;&#13;&#10;&lt;/ul&gt;" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" options="Rising Edge&#13;&#10;Falling Edge&#13;&#10;Both Edges" value="Falling Edge" widgetName="gcombo_external_clock_edge" toolTipText="Setting of bitfield DX1CR.CM"/>
                        <p1:GCombo bounds="163, 33, 147, 21" description="This field defines the frequency fPIN, input to the dividers of the BRG.&lt;br&gt;&#13;&#10;&lt;ul&gt;&#13;&#10;&lt;li&gt;Internal Source (FD): The fractional divider frequency fFD is selected.&lt;/li&gt;&#13;&#10;&lt;li&gt;External Source (DX1T): The trigger signal DX1T defines fPIN.&lt;/li&gt;&#13;&#10;&lt;/ul&gt;" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" options="Internal Source (FD)&#13;&#10;External Source (DX1)" value="Internal Source (FD)" widgetName="gcombo_clock_selection" toolTipText="Setting of bitfield BRG.CLKSEL"/>
                        <p1:GLabel bounds="13, 36, 77, 15" manifestObj="true" text="Clock source:" widgetName="glabel_clock_selection" toolTipText="Setting of bitfield BRG.CLKSEL"/>
                        <p1:GLabel bounds="13, 176, 90, 15" manifestObj="true" text="Pre-divider:" toolTipText="Setting of bitfield BRG.PCTQ" widgetName="glabel_predivider"/>
                        <p1:GInteger bounds="163, 172, 147, 23" description="This field indicates length of a time quantum tq for the time quanta counter in the protocol pre-processor (tQ = (PCTQ + 1) / fCTQIN).&lt;br&gt;&#13;&#10;" enabled="false" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="3" minValue="0" toolTipText="Setting of bitfield BRG.PCTQ" value="0" widgetName="ginteger_predivider"/>
                        <p1:GLabel bounds="13, 211, 72, 15" manifestObj="true" text="Step value:" toolTipText="Setting of bitfield FDR.STEP" widgetName="glabel_step_value"/>
                        <p1:GInteger bounds="163, 207, 147, 23" description="In normal divider mode, this field contains the reload value for RESULT after RESULT has reached 0x3FF. In fractional divider mode, it indicates the value added to RESULT with each input clock cycle.&lt;br&gt;&#13;&#10;Bitfield FDR.STEP" enabled="false" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="1023" minValue="0" toolTipText="Setting of bitfield FDR.STEP" value="0" widgetName="ginteger_step_value"/>
                        <p1:GInteger x:Style="NONE" minValue="1" maxValue="1024" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" manifestObj="true" widgetName="ginteger_divider_factor_external_clk" bounds="163, 102, 147, 23" value="1"/>
                        <p1:GInteger x:Style="NONE" minValue="10" maxValue="25" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" manifestObj="true" widgetName="ginteger_oversampling" bounds="163, 137, 147, 23" value="10"/>
                    </p1:GGroup>
                    <p1:GLabel bounds="19, 329, 90, 15" manifestObj="true" text="Symbol timing:" toolTipText="Setting of bitfield BRG.DCTQ + 1" widgetName="glabel_symbol_timing_slave"/>
                    <p1:GCombo mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" widgetName="gcombo_symbol_timing_slave" bounds="135, 326, 239, 21" options="10 Time Quanta Per Symbol (100 kBaud)&#13;&#10;25 Time Quanta Per Symbol (400 kBaud)" value="10 Time Quanta Per Symbol (100 kBaud)" description="Oversampling or symbol timing is the number of time quanta that defines one symbol(logic 0 or 1).&lt;br&gt;&#13;&#10;For I2C speed 100KHz, symbol timing should be 10 time quanta&lt;br&gt;&#13;&#10;For I2C speed more than 100KHz, symbol timing should be 25 time quanta.&lt;br&gt;&#13;&#10;This value should be selected based on the master configuration."/>
                </p1:Tab>
            </p1:GTab.control>
        </p1:GTab>
		<p1:GTab text="Events" widgetName="gtab_events" visible="true" enabled="true" manifestObj="true">
			<p1:GTab.control>
				<p1:Tab>
					<p1:GGroup bounds="12, 14, 501, 395" manifestObj="true" text="Protocol-Specific Events" widgetName="ggroup_protocol_events">
						<p1:GCheck bounds="14, 29, 199, 16" description="On selecting this option, start condition received event will be enabled to generate interrupt. &lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.SCRIEN" manifestObj="true" text="Start condition correctly received" widgetName="gcheck_scr_event" toolTipText="Bitfield PCR_IICmode.SCRIEN"/>
						<p1:GCheck bounds="14, 128, 149, 16" description="On selecting this option, arbitration lost event will be enabled to generate interrupt.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.ARLIEN" manifestObj="true" text="Master arbitration lost" widgetName="gcheck_arl_event" toolTipText="Bitfield PCR_IICmode.ARLIEN"/>
						<p1:GCheck bounds="14, 62, 244, 16" description="On selecting this option, repeated start condition received event will be enabled to generated interrupt.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.RSCRIEN" manifestObj="true" text="Repeated start condition correctly received" widgetName="gcheck_rcsr_event" toolTipText="Bitfield PCR_IICmode.RSCRIEN"/>
						<p1:GCheck bounds="14, 161, 143, 16" description="On selecting this option, slave read request received event will be enabled to generate interrupt.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.SRRIEN" manifestObj="true" text="Slave read requested" widgetName="gcheck_srr_event" toolTipText="Bitfield PCR_IICmode.SRRIEN"/>
						<p1:GCheck bounds="14, 95, 209, 16" description="On selecting this option, stop condition received event will be enabled to generate interrupt.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.PCRIEN" manifestObj="true" text="Stop condition transferred correctly" widgetName="gcheck_pcr_event" toolTipText="Bitfield PCR_IICmode.PCRIEN"/>
						<p1:GCheck bounds="14, 194, 142, 16" description="On selecting this option, master mode acknowledgement received event will be enabled to generate interrupt.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.ACKIEN" manifestObj="true" text="Acknowledge received" widgetName="gcheck_ack_event" toolTipText="Bitfield PCR_IICmode.ACKIEN"/>
						<p1:GCheck bounds="14, 227, 173, 16" description="On selecting this option, non-acknowledgement event will be enabled to generate interrupt.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.NACKIEN" manifestObj="true" text="Non-acknowledge received" widgetName="gcheck_nack_event" toolTipText="Bitfield PCR_IICmode.NACKIEN"/>
						<p1:GCheck bounds="14, 260, 484, 16" description="On selecting this option, error interrupt event will be enabled.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.ERRIEN" manifestObj="true" text="Start or stop condition not at the expected position in a frame or, as a slave, 10-bit " widgetName="gcheck_err_event"/>
						<p1:GCheck bounds="13, 296, 151, 16" description="On selecting this option, error interrupt event will be enabled. Interrupt will be generated when a wrong TDF(Transmit Data Format) code is put in transmit buffer register.&lt;br&gt;&#13;&#10;Bitfield PCR_IICmode.ERRIEN" manifestObj="true" text="Wrong TDF code found" widgetName="gcheck_wtdf_event"/>
						<p1:GCheck bounds="13, 359, 208, 16" description="On selecting this option, data lost event will be enabled to generate interrupt.&lt;br&gt;&#13;&#10;Bitfield CCR.DLIEN" manifestObj="true" text="Data lost" widgetName="gcheck_datalost_event" toolTipText="Event generated when receive buffer is not able to accommodate&#13;&#10;incoming data."/>
						<p1:GLabel text="address interrupted by a stop condition after the first address byte." visible="true" manifestObj="true" widgetName="glabel_err_event_2" bounds="30, 278, 359, 16"/>
						<p1:GCheck bounds="13, 326, 208, 16" description="On selecting this option, the baud rate generator event is enabled and indicates that the capture mode timer reached its maximum value." manifestObj="true" text="Baudrate generator" widgetName="gcheck_brg_event"/>
					</p1:GGroup>
				</p1:Tab>
			</p1:GTab.control>
		</p1:GTab>
		<p1:GTab text="FIFO" widgetName="gtab_fifo" visible="true" enabled="true" manifestObj="true">
			<p1:GTab.control>
				<p1:Tab>
					<p1:GGroup bounds="12, 16, 501, 88" manifestObj="true" text="Transmit FIFO Buffer Configuration" widgetName="ggroup_tx_fifo_buffer_conf">
						<p1:GLabel bounds="14, 54, 218, 15" manifestObj="true" text="Tx FIFO data pointer (TBCTR.DPTR):" widgetName="glabel_tx_fifo_data_pointer"/>
						<p1:GLabel bounds="14, 24, 217, 15" manifestObj="true" text="No. of FIFO buffer entries (TBCTR.SIZE):" widgetName="glabel_number_tx_fifo_entries"/>
						<p1:GCombo bounds="435, 21, 51, 21" description="Configure the desired transmit FIFO buffer size.  A FIFO with a size of 64 words is shared between two channels of a USIC module.&#13;&#10;The I2C_CONFIG APP uses one such channels for communication. This share of the FIFO buffer is further shared between the transmit and receive functionalities. The size configured in this box will be reserved for the transmit FIFO.&lt;br&gt;&#13;&#10;Note: The DAVE IDE might display an error message if the desired FIFO size could not be allocated.This could be because of another channel or receive functionality using a higher FIFO size.&lt;br&gt;&#13;&#10;&lt;ul&gt;&#13;&#10;&lt;li&gt;0:  The transmit FIFO is disabled.&lt;/li&gt;&#13;&#10;&lt;li&gt;2: 2 words of the FIFO will be reserved for the I2C_CONFIG APP transmit function.&lt;/li&gt;&#13;&#10;&lt;li&gt;4: 4 words of the FIFO will be reserved for the I2C_CONFIG APP transmit function.&lt;/li&gt;&#13;&#10;&lt;li&gt;8: 8 words of the FIFO will be reserved for the I2C_CONFIG APP transmit function.&lt;/li&gt;&#13;&#10;&lt;li&gt;16: 16 words of the FIFO will be reserved for the I2C_CONFIG APP transmit function.&lt;/li&gt;&#13;&#10;&lt;li&gt;32: 32 words of the FIFO will be reserved for the I2C_CONFIG APP transmit function.&lt;/li&gt;&#13;&#10;&lt;li&gt;64: The entire FIFO of the USIC module will be reserved for the I2C_CONFIG APP transmit function.&lt;/li&gt;&#13;&#10;&lt;/ul&gt;" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" options="0&#13;&#10;2&#13;&#10;4&#13;&#10;8&#13;&#10;16&#13;&#10;32&#13;&#10;64" value="0" widgetName="gcombo_number_tx_fifo_entries"/>
						<p1:GInteger bounds="435, 50, 51, 23" description="This field indicates the start value of the transmit buffer pointers when assigning the FIFO entries to the transmit FIFO buffer. A value of zero indicates that the buffer is empty." enabled="false" format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="64" minValue="0" value="0" widgetName="ginteger_tx_fifo_data_pointer"/>
					</p1:GGroup>
					<p1:GGroup bounds="12, 115, 501, 88" manifestObj="true" text="Receive FIFO Buffer Configuration" widgetName="ggroup_rx_fifo_buffer_conf">
						<p1:GLabel bounds="14, 54, 210, 15" manifestObj="true" text="Rx FIFO data pointer (RBCTR.DPTR):" widgetName="glabel_rx_fifo_data_pointer"/>
						<p1:GLabel bounds="14, 24, 208, 15" manifestObj="true" text="No. of FIFO buffer entries (RBCTR.SIZE):" widgetName="glabel_number_rx_fifo_entries"/>
						<p1:GCombo bounds="435, 21, 51, 21" description="Configure the desired receive FIFO buffer size.  A FIFO with a size of 64 words is shared between two channels of a USIC module.&#13;&#10;The I2C_CONFIG APP uses one such channels for communication. This share of the FIFO buffer is further shared between the transmit and receive functionalities. The size configured in this box will be reserved for the receive FIFO.&lt;br&gt;&#13;&#10;Note: The DAVE IDE might display an error message if the desired FIFO size could not be allocated.This could be because of another channel or receive functionality using a higher FIFO size.&lt;br&gt;&#13;&#10;&lt;ul&gt;&#13;&#10;&lt;li&gt;0:  The receive FIFO is disabled.&lt;/li&gt;&#13;&#10;&lt;li&gt;2:  2 words of the FIFO will be reserved for the I2C_CONFIG APP receive function.&lt;/li&gt;&#13;&#10;&lt;li&gt;4: 4 words of the FIFO will be reserved for the I2C_CONFIG APP receive function.&lt;/li&gt;&#13;&#10;&lt;li&gt;8: 8 words of the FIFO will be reserved for the I2C_CONFIG APP receive function.&lt;/li&gt;&#13;&#10;&lt;li&gt;16: 16 words of the FIFO will be reserved for the I2C_CONFIG APP receive function.&lt;/li&gt;&#13;&#10;&lt;li&gt;32: 32 words of the FIFO will be reserved for the I2C_CONFIG APP receive function.&lt;/li&gt;&#13;&#10;&lt;li&gt;64: The entire FIFO of the USIC module will be reserved for the I2C_CONFIG APP receive function.&lt;/li&gt;&#13;&#10;&lt;/ul&gt;" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" options="0&#13;&#10;2&#13;&#10;4&#13;&#10;8&#13;&#10;16&#13;&#10;32&#13;&#10;64" value="0" widgetName="gcombo_number_rx_fifo_entries"/>
						<p1:GInteger bounds="435, 50, 51, 23" description="This field indicates the start value of the receive buffer pointers when assigning the FIFO entries to the receive FIFO buffer. A value of zero indicates that the buffer is empty." enabled="false" format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="64" minValue="0" value="0" widgetName="ginteger_rx_fifo_data_pointer"/>
					</p1:GGroup>
					<p1:GGroup bounds="12, 217, 501, 99" manifestObj="true" text="Transmit FIFO Events Configuration" widgetName="ggroup_tx_fifo_interrupts_conf">
						<p1:GLabel bounds="14, 31, 322, 15" manifestObj="true" text="Limit for the transmit buffer event generation (TBCTR.LIMIT):" widgetName="glabel_limit_for_transmit_events"/>
						<p1:GInteger bounds="435, 27, 51, 23" description="Define the target filling level of the transmit FIFO buffer that is used for the standard transmit buffer event detection." format="(com.ifx.davex.ui.controls.util.AppUiConstants).DEC" mandatory="(com.ifx.davex.ui.controls.util.AppUiConstants).FALSE" manifestObj="true" maxValue="63" minValue="0" value="0" widgetName="ginteger_limit_for_transmit_events"/>
						<p1:GLabel bounds="14, 55, 449, 35" manifestObj="true" text="Note: the transmit buffer event is triggered when the filling level is falling&#13;&#10;below the limit (TBCTR.LOF = 0)." widgetName="glabel_transmit_limit_for_event"/>
					</p1:GGroup>
					<p1:GGroup bounds="12, 329, 501, 99" manifestObj="true" text="Receive FIFO Events Configuration" widgetName="ggroup_rx_fifo_events_conf">
						<p1:GLabel bounds="14, 31, 389, 15" manifestObj="true" text="Filling level for the receive buffer event detection (RBCTR.LIMIT):" widgetName="glabel_limit_for_receive_events"/>
